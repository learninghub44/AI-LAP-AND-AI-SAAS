# Railway production variables for RelayGrid AI.
# Add these in Railway's service Variables tab. Do not commit real secrets.

NODE_ENV=production
HOST=0.0.0.0

# Railway provides PORT automatically. Do not hard-code it unless debugging.
# PORT=3001

# Generate 32 random bytes as hex:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-char-hex-key

# Public domains
APP_PUBLIC_URL=https://app.relaygrid.ai
API_PUBLIC_URL=https://api.relaygrid.ai
DASHBOARD_ORIGINS=https://app.relaygrid.ai,https://www.relaygrid.ai

# SaaS database. Use Railway Postgres for the hosted API gateway, or Supabase
# Postgres if you want Supabase Auth/RLS in the customer portal.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Payment provider
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_WEBHOOK_SECRET=replace-with-webhook-secret
PAYSTACK_CALLBACK_URL=https://api.relaygrid.ai/billing/paystack/callback

# Catalog and license service
PREMIUM_SITE_URL=https://www.relaygrid.ai
CATALOG_BASE_URL=https://api.relaygrid.ai
CATALOG_PUBKEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
CATALOG_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# SaaS gateway controls
SAAS_MODE=1
DEFAULT_FREE_MONTHLY_REQUESTS=100
API_KEY_PREFIX=rg_
API_KEY_PEPPER=replace-with-random-server-side-pepper
SAAS_FREE_MODEL_ID=openai-fast
SAAS_FAST_MODEL_ID=openai-fast
# Leave these unset to let paid users request raw model IDs directly.
# SAAS_BALANCED_MODEL_ID=some-balanced-catalog-model
# SAAS_ADVANCED_MODEL_ID=some-advanced-catalog-model
REQUEST_ANALYTICS_RETENTION_DAYS=180
REQUEST_ANALYTICS_MAX_ROWS=1000000

# Optional Supabase customer portal settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key
