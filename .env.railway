# ============================================================
# Cotell AI — Railway Production Environment Variables
# ============================================================
# Paste these into Railway → Your Service → Variables tab.
# Never commit this file with real secrets to GitHub.
# ============================================================

# ── Core ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── SaaS Mode ───────────────────────────────────────────────
# Set to 1 to enable multi-tenant customer API key auth,
# plan entitlement checks, and usage tracking.
SAAS_MODE=1

# ── Database ────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when you add a Postgres
# service to the project. Leave the placeholder here as a
# reminder — Railway will override it automatically.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Optional: disable SSL for local/dev Postgres only.
# Leave unset (or set to 1) for Railway production.
# DATABASE_SSL=0

# ── Security Secrets ────────────────────────────────────────
# IMPORTANT: Replace these with your own generated values.
# Generate new ones with: openssl rand -hex 32

# Signs JWT tokens for admin dashboard sessions.
JWT_SECRET=09dd106f973ab4c3c7ce4eeb124cf77fc434a4cfee302f8b1a597ffb4a8011c3

# Pepper mixed into customer API key hashes (one-way, never reversible).
# If you change this after launch, ALL existing customer keys break.
API_KEY_PEPPER=654374af854371d5b5837bc1dd66035ab4ba1d63ef87c9e2b54ad198f8de435d

# ── CORS / Dashboard ────────────────────────────────────────
# Add your Railway public URL here once deployed, e.g:
# DASHBOARD_ORIGINS=https://cotell-ai.up.railway.app
DASHBOARD_ORIGINS=

# ── SaaS Free-Tier Model Routing ────────────────────────────
# The model ID the router uses when a free-plan customer
# requests model="auto", "free", or sends no model.
# Pollinations openai-fast is keyless — works with zero setup.
SAAS_FREE_MODEL_ID=openai-fast

# Model IDs for each paid plan group (used when customer sends
# model="fast", "balanced", "advanced" etc.)
SAAS_FAST_MODEL_ID=openai-fast
SAAS_BALANCED_MODEL_ID=openai-fast
SAAS_ADVANCED_MODEL_ID=openai-fast

# ── Paystack (add when ready for payments) ──────────────────
# Get these from dashboard.paystack.com → Settings → API Keys
# PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
# PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Optional: Provider Key Env Overrides ────────────────────
# You can also set provider keys here as env vars instead of
# through the admin dashboard UI. Dashboard UI is recommended.
# GROQ_API_KEY=gsk_xxxx
# GEMINI_API_KEY=AIzaxxxx
# OPENROUTER_API_KEY=sk-or-xxxx
