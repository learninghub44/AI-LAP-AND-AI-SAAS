# ============================================================
# Cotell AI — Railway Production Environment Variables
# ============================================================
# Paste these into Railway → Your Service → Variables tab.
# ============================================================

# ── Core ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── SaaS Mode ───────────────────────────────────────────────
# IMPORTANT: Set to 0 for now until you add a Postgres service.
# The server uses SQLite by default. Once you add Railway Postgres,
# change this to 1 and add DATABASE_URL.
SAAS_MODE=0

# ── Security Secrets ────────────────────────────────────────
JWT_SECRET=09dd106f973ab4c3c7ce4eeb124cf77fc434a4cfee302f8b1a597ffb4a8011c3
API_KEY_PEPPER=654374af854371d5b5837bc1dd66035ab4ba1d63ef87c9e2b54ad198f8de435d

# ── CORS ────────────────────────────────────────────────────
# Add your Railway public URL here once deployed, e.g:
# DASHBOARD_ORIGINS=https://cotell-ai.up.railway.app
DASHBOARD_ORIGINS=

# ── Free Model Routing ───────────────────────────────────────
SAAS_FREE_MODEL_ID=openai-fast
SAAS_FAST_MODEL_ID=openai-fast
SAAS_BALANCED_MODEL_ID=openai-fast
SAAS_ADVANCED_MODEL_ID=openai-fast

# ── Paystack (add when ready for payments) ──────────────────
# PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
